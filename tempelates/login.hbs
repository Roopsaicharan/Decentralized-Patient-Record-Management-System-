<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Health Care System</title>
    <link rel="stylesheet" href="/login.css">
</head>
<body>
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <span class="logo">🏥</span>
                <h1>Welcome Back</h1>
                <p>Sign in to access the MediCore Dashboard</p>
            </div>
            
            <form action="/login" method="post" class="auth-form">
                <div class="input-group">
                    <label>Username</label>
                    <input placeholder="Enter your name" name="name" type="text" required>
                </div>
                
                <div class="input-group">
                    <label>Password</label>
                    <input placeholder="••••••••" name="password" type="password" required>
                </div>
                
                <button class="btn-submit" type="submit">Sign In</button>
            </form>
            
            {{#if message}}
                <div class="alert success-alert">{{message}}</div>
            {{/if}}
            
            <div class="auth-footer">
                <p>Don't have an account? <a href="/signup">Create one here</a></p>
            </div>
        </div>
    </div>
</body>
</html>
