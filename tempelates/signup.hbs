<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Signup - Health Care System</title>
    <link rel="stylesheet" href="/signup.css">
</head>
<body>
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <span class="logo">🏥</span>
                <h1>Create Account</h1>
                <p>Join the MediCore Hospital Network</p>
            </div>
            
            <form action="/signup" method="post" class="auth-form">
                <div class="input-group">
                    <label>Full Name</label>
                    <input placeholder="Enter your full name" name="name" type="text" required>
                </div>
                
                <div class="input-group">
                    <label>Password</label>
                    <input placeholder="Create a strong password" name="password" type="password" required>
                </div>
                
                <button class="btn-submit" type="submit">Sign Up</button>
            </form>
            
            {{#if message}}
                <div class="alert success-alert">{{message}}</div>
            {{/if}}
            
            <div class="auth-footer">
                <p>Already have an account? <a href="/">Log in here</a></p>
            </div>
        </div>
    </div>
</body>
</html>
