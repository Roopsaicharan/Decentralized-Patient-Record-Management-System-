<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/home.css">
    <link rel="stylesheet" href="/feature1.css">
    <title>Prescription Management</title>
</head>
<body>
    <div class="dashboard-container">
        <!-- Sidebar Navigation -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <span class="logo">⚕️</span>
                <h2>MediChain</h2>
            </div>
            
            <nav class="sidebar-nav">
                <div class="nav-section">Main Menu</div>
                <a href="/home" class="nav-item">
                    <span class="nav-icon">📊</span>
                    System Overview
                </a>
                
                <div class="nav-section">Patient Portal</div>
                <a href="/feature0" class="nav-item">
                    <span class="nav-icon">📝</span>
                    Patient Registration
                </a>
                <a href="/feature1" class="nav-item">
                    <span class="nav-icon">🤖</span>
                    AI Disease Prediction
                </a>
                <a href="/feature5" class="nav-item">
                    <span class="nav-icon">👨‍⚕️</span>
                    Assign Doctor
                </a>

                <div class="nav-section">Medical & Admin</div>
                <a href="/feature2" class="nav-item active">
                    <span class="nav-icon">📋</span>
                    Prescription Management
                </a>
                <a href="/feature4" class="nav-item">
                    <span class="nav-icon">🔗</span>
                    Blockchain Verification
                </a>
            </nav>
            
            <div class="sidebar-footer">
                <a href="/" class="nav-item text-danger">
                    <span class="nav-icon">🚪</span>
                    Secure Logout
                </a>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="main-content">
            <!-- Topbar -->
            <header class="topbar">
                <div class="search-bar">
                    <span class="search-icon">🔍</span>
                    <input type="text" placeholder="Search patient ID or blockchain hash...">
                </div>
                <div class="user-profile">
                    <div class="network-badge">
                        <span class="pulse-dot"></span> Sepolia Network
                    </div>
                    <div class="avatar">U</div>
                    <span>Auth User</span>
                </div>
            </header>

            <!-- Dashboard Content -->
            <div class="content-wrapper">
                <div class="module-header">
                    <h1>Digital Prescription Creation</h1>
                    <p>Create secure prescriptions to be hashed on IPFS and stored on the Ethereum blockchain.</p>
                </div>

                <div class="tables-grid">
                    <!-- Prescription Form -->
                    <div class="prediction-card" style="margin-top: 0;">
                        <form id="prescriptionForm" class="prediction-form">
                            
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                                <div>
                                    <label>Patient ID</label>
                                    <input value="PT-1042" placeholder="e.g. PT-1042" name="patient_id" type="text" required style="width: 100%; padding: 12px; border: 2px solid var(--border-color); border-radius: 8px; font-family: 'Outfit', sans-serif;">
                                </div>
                                <div>
                                    <label>Diagnosis</label>
                                    <input value="Type 2 Diabetes" placeholder="e.g. Type 2 Diabetes" name="diagnosis" type="text" required style="width: 100%; padding: 12px; border: 2px solid var(--border-color); border-radius: 8px; font-family: 'Outfit', sans-serif;">
                                </div>
                            </div>

                            <label style="margin-top: 10px; display: block;">Medication</label>
                            <input value="Metformin 500mg" placeholder="e.g. Metformin 500mg" name="medication" type="text" required style="width: 100%; padding: 12px; border: 2px solid var(--border-color); border-radius: 8px; font-family: 'Outfit', sans-serif;">

                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-top: 10px;">
                                <div>
                                    <label>Dosage Instructions</label>
                                    <input value="Twice daily after meals" placeholder="e.g. Twice daily after meals" name="dosage" type="text" required style="width: 100%; padding: 12px; border: 2px solid var(--border-color); border-radius: 8px; font-family: 'Outfit', sans-serif;">
                                </div>
                                <div>
                                    <label>Duration</label>
                                    <input value="30 Days" placeholder="e.g. 30 Days" name="duration" type="text" required style="width: 100%; padding: 12px; border: 2px solid var(--border-color); border-radius: 8px; font-family: 'Outfit', sans-serif;">
                                </div>
                            </div>

                            <label style="margin-top: 10px; display: block;">Precautions / Notes</label>
                            <textarea placeholder="Any additional notes for the patient..." name="notes" rows="3" style="width: 100%; padding: 12px; border: 2px solid var(--border-color); border-radius: 8px; font-family: 'Outfit', sans-serif; resize: vertical;">Patient advised to monitor blood sugar levels regularly and avoid high-carb meals.</textarea>
                            
                            <button type="button" onclick="submitPrescription()" class="btn btn-primary" style="margin-top: 15px; width: 100%;">Sign & Upload to IPFS</button>
                        </form>
                    </div>

                    <!-- Process Visualizer -->
                    <div class="table-card system-card">
                        <div class="table-header">
                            <h2>Decentralization Pipeline</h2>
                        </div>
                        <div style="padding: 24px;">
                            <div id="step-1" style="display: flex; align-items: center; gap: 15px; margin-bottom: 20px; opacity: 0.5;">
                                <div style="width: 40px; height: 40px; border-radius: 50%; background: #f1f5f9; display: flex; align-items: center; justify-content: center; font-weight: bold;">1</div>
                                <div>
                                    <strong style="display: block;">Generate Document</strong>
                                    <span style="font-size: 0.85rem; color: var(--text-muted);">Format prescription as JSON</span>
                                </div>
                            </div>
                            <div id="step-2" style="display: flex; align-items: center; gap: 15px; margin-bottom: 20px; opacity: 0.5;">
                                <div style="width: 40px; height: 40px; border-radius: 50%; background: #f1f5f9; display: flex; align-items: center; justify-content: center; font-weight: bold;">2</div>
                                <div>
                                    <strong style="display: block;">Upload to IPFS</strong>
                                    <span style="font-size: 0.85rem; color: var(--text-muted);">Generate unique content hash</span>
                                </div>
                            </div>
                            <div id="step-3" style="display: flex; align-items: center; gap: 15px; opacity: 0.5;">
                                <div style="width: 40px; height: 40px; border-radius: 50%; background: #f1f5f9; display: flex; align-items: center; justify-content: center; font-weight: bold;">3</div>
                                <div>
                                    <strong style="display: block;">Blockchain Registry</strong>
                                    <span style="font-size: 0.85rem; color: var(--text-muted);">Store IPFS hash on smart contract</span>
                                </div>
                            </div>
                            
                            <div id="success-box" style="margin-top: 30px; display: none; padding: 15px; background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 8px;">
                                <strong style="color: var(--primary-color); display: block; margin-bottom: 5px;">✅ Success!</strong>
                                <span style="font-size: 0.8rem; font-family: 'JetBrains Mono', monospace; word-break: break-all; color: var(--text-dark);">
                                    IPFS Hash: <br><span id="fake-hash" style="color: var(--primary-color);"></span>
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </main>
    </div>

    <script>
        function submitPrescription() {
            // Step 1 animation
            document.getElementById('step-1').style.opacity = '1';
            document.getElementById('step-1').querySelector('div').style.background = '#dcfce7';
            document.getElementById('step-1').querySelector('div').style.color = '#16a34a';
            
            setTimeout(() => {
                // Step 2 animation
                document.getElementById('step-2').style.opacity = '1';
                document.getElementById('step-2').querySelector('div').style.background = '#dcfce7';
                document.getElementById('step-2').querySelector('div').style.color = '#16a34a';
                
                setTimeout(() => {
                    // Step 3 animation
                    document.getElementById('step-3').style.opacity = '1';
                    document.getElementById('step-3').querySelector('div').style.background = '#dcfce7';
                    document.getElementById('step-3').querySelector('div').style.color = '#16a34a';
                    
                    // Show success
                    const fakeHash = 'Qm' + Math.random().toString(36).substring(2, 15) + Math.random().toString(36).substring(2, 15);
                    document.getElementById('fake-hash').innerText = fakeHash;
                    document.getElementById('success-box').style.display = 'block';
                    
                    // Clear form
                    document.getElementById('prescriptionForm').reset();
                    
                }, 1000);
            }, 1000);
        }
    </script>
</body>
</html>
