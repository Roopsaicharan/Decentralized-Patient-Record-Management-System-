<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Doctor Access Management</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/home.css">
    <link rel="stylesheet" href="/feature1.css">
</head>
<body>
    <div class="dashboard-container">
        <!-- Sidebar Navigation -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <span class="logo">🏥</span>
                <h2>MediCore</h2>
            </div>
            
            <nav class="sidebar-nav">
                <a href="/home" class="nav-item">
                    <span class="nav-icon">📊</span>
                    Overview
                </a>
                <a href="/feature0" class="nav-item">
                    <span class="nav-icon">📝</span>
                    Patient Form
                </a>
                <a href="/feature1" class="nav-item">
                    <span class="nav-icon">🧠</span>
                    Disease Prediction
                </a>
                <a href="/feature2" class="nav-item">
                    <span class="nav-icon">💊</span>
                    Treatment Plans
                </a>
                <a href="/feature4" class="nav-item">
                    <span class="nav-icon">🔗</span>
                    Blockchain Data
                </a>
                <a href="/feature5" class="nav-item active">
                    <span class="nav-icon">👨‍⚕️</span>
                    Doctor Access
                </a>
            </nav>
            
            <div class="sidebar-footer">
                <a href="/" class="nav-item text-danger">
                    <span class="nav-icon">🚪</span>
                    Logout
                </a>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="main-content">
            <!-- Topbar -->
            <header class="topbar">
                <div class="search-bar">
                    <span class="search-icon">🔍</span>
                    <input type="text" placeholder="Search patients...">
                </div>
                <div class="user-profile">
                    <div class="avatar">👤</div>
                    <span>Dr. Admin</span>
                </div>
            </header>

            <!-- Dashboard Content -->
            <div class="content-wrapper">
                <div class="module-header">
                    <h1>Doctor Access Management</h1>
                    <p>Assign doctors to patients to grant them access to records.</p>
                </div>

                <div class="prediction-card" style="max-width: 500px;">
                    <form action="/feature5" method="post" class="prediction-form">
                        <label>Patient ID</label>
                        <input placeholder="e.g. PT-1042" name="patient_id" type="text" required style="width: 100%; padding: 12px; border: 2px solid var(--border-color); border-radius: 8px; font-family: 'Inter', sans-serif;">
                        
                        <label>Doctor ID</label>
                        <input placeholder="e.g. DOC-901" name="Doctor_id" type="text" required style="width: 100%; padding: 12px; border: 2px solid var(--border-color); border-radius: 8px; font-family: 'Inter', sans-serif;">
                        
                        <button type="submit" class="btn btn-primary" style="margin-top: 10px;">Grant Access</button>
                    </form>
                    
                    {{#if message}}
                        <div style="margin-top: 20px; font-weight: 600; padding: 15px; border-radius: 8px; background-color: #f0fdf4; color: var(--success-color); border: 1px solid #bbf7d0;">
                            {{message}}
                        </div>
                    {{/if}}
                </div>
            </div>
        </main>
    </div>
</body>
</html>
