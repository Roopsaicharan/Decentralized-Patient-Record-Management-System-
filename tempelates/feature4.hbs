<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blockchain Data Viewer</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/home.css">
    <link rel="stylesheet" href="/feature1.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
</head>
<body>
    <div class="dashboard-container">
        <!-- Sidebar Navigation -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <span class="logo">🏥</span>
                <h2>MediCore</h2>
            </div>
            
            <nav class="sidebar-nav">
                <a href="/home" class="nav-item">
                    <span class="nav-icon">📊</span>
                    Overview
                </a>
                <a href="/feature0" class="nav-item">
                    <span class="nav-icon">📝</span>
                    Patient Form
                </a>
                <a href="/feature1" class="nav-item">
                    <span class="nav-icon">🧠</span>
                    Disease Prediction
                </a>
                <a href="/feature2" class="nav-item">
                    <span class="nav-icon">💊</span>
                    Treatment Plans
                </a>
                <a href="/feature4" class="nav-item active">
                    <span class="nav-icon">🔗</span>
                    Blockchain Data
                </a>
                <a href="/feature5" class="nav-item">
                    <span class="nav-icon">👨‍⚕️</span>
                    Doctor Access
                </a>
            </nav>
            
            <div class="sidebar-footer">
                <a href="/" class="nav-item text-danger">
                    <span class="nav-icon">🚪</span>
                    Logout
                </a>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="main-content">
            <!-- Topbar -->
            <header class="topbar">
                <div class="search-bar">
                    <span class="search-icon">🔍</span>
                    <input type="text" placeholder="Search patients...">
                </div>
                <div class="user-profile">
                    <div class="avatar">👤</div>
                    <span>Dr. Admin</span>
                </div>
            </header>

            <!-- Dashboard Content -->
            <div class="content-wrapper">
                <div class="module-header">
                    <h1>Blockchain Data Viewer</h1>
                    <p>Fetch immutable patient records directly from the Ethereum network.</p>
                </div>

                <div class="prediction-card">
                    <form id="doctorSearchForm" method="post" class="prediction-form">
                        <label>Doctor ID Search</label>
                        <input value="DOC-901" id="Doctor_id" placeholder="Enter Doctor ID (e.g. DOC-123)" type="text" style="width: 100%; max-width: 400px; padding: 12px; border: 2px solid var(--border-color); border-radius: 8px; font-family: 'Outfit', sans-serif;">
                        <button type="submit" class="btn btn-primary" style="margin-top: 10px;">Fetch Blockchain Data</button>
                    </form>

                    <div id="blockchain-data" style="margin-top: 30px; font-family: 'SF Mono', 'Fira Code', monospace; font-size: 0.85rem; background: #1e293b; color: #38bdf8; padding: 20px; border-radius: 12px; overflow-x: auto;">
                        <p style="color: #94a3b8;">// Results will appear here...</p>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        $(document).ready(function () {
            $('#doctorSearchForm').submit(function (e) {
                e.preventDefault();

                var doctorId = $('#Doctor_id').val();
                
                $('#blockchain-data').html('<p style="color: #fcd34d;">// Fetching blocks, please wait...</p>');

                // Send a POST request to fetch data
                $.post('/feature4/blockchain', { Doctor_id: doctorId }, function (response) {
                    if (response.success) {
                        var resultHTML = '<pre style="margin: 0;">';
                        resultHTML += JSON.stringify(response.patients, null, 2); // Direct JSON output
                        resultHTML += '</pre>';
                        $('#blockchain-data').html(resultHTML);
                    } else {
                        $('#blockchain-data').html(`<p style="color: #f87171;">// Error: ${response.message}</p>`);
                    }
                }).fail(function () {
                    $('#blockchain-data').html("<p style="color: #f87171;">// Error fetching patient data. Please try again later.</p>");
                });
            });
        });
    </script>
</body>
</html>